{
    "version" : 8,
    "cmakeMinimumRequired": {
        "major" : 4,
        "minor" : 3,
        "patch" : 0
    },
    "configurePresets" : [
        {
            "name" : "debug",
            "displayName" : "debug",
            "description" : "Debug Build using Clang++ and Ninja",
            "generator" : "Ninja",
            "binaryDir" : "${sourceDir}/build/debug",
            "cacheVariables" : {
                "CMAKE_CXX_COMPILER" : "clang++",
                "CMAKE_BUILD_TYPE" : "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name" : "release",
            "displayName" : "release",
            "description" : "Release Build using Clang++ and Ninja",
            "generator" : "Ninja",
            "binaryDir" : "${sourceDir}/build/release",
            "cacheVariables" : {
                "CMAKE_CXX_COMPILER" : "clang++",
                "CMAKE_BUILD_TYPE" : "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        }
    ],
    "buildPresets" : [
        {
            "name" : "debug",
            "configurePreset" : "debug"
        },
        {
            "name" : "release",
            "configurePreset" : "release"
        }
   ]
}
